  tft.drawRoundRect(10, 205, 300, 55, 8, ILI9341_GREEN);
  tft.setTextColor(ILI9341_GREEN);
  tft.setTextSize(2);
  tft.setCursor(20, 218);
  tft.print("TARGET pH: 5.5-6.5");

  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(1);
