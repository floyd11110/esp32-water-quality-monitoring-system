  tft.setTextColor(ILI9341_GREEN);
  tft.setTextSize(2);
  tft.setCursor(20, 60);
  tft.print("TEMP");

  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(3);
  tft.setCursor(20, 85);

  if (tempC == DEVICE_DISCONNECTED_C) {
    tft.print("ERR");
  } else {
    tft.print(tempC, 1);
    tft.print("C");
  }

  tft.setTextColor(getTempStatusColor());
