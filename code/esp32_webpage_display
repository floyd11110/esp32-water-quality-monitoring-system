#include <WiFi.h>
#include <WebServer.h>
#include <OneWire.h>
#include <DallasTemperature.h>
#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ILI9341.h>




const char* ssid = "wifi name";
const char* password = "password";


#define PH_PIN 34
#define ONE_WIRE_BUS 27

#define TFT_CS   5
#define TFT_DC   2
#define TFT_RST  4



Adafruit_ILI9341 tft = Adafruit_ILI9341(TFT_CS, TFT_DC, TFT_RST);


OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);


WebServer server(80);


float neutralVoltage = 2.40;   
float slope = 0.18;            
float normalTolerance = 0.10;  


float phVoltage = 0.0;
float estimatedPH = 7.0;
float tempC = 0.0;

String phStatus = "UNKNOWN";
String tempStatus = "UNKNOWN";

unsigned long lastSensorRead = 0;
unsigned long lastTftUpdate = 0;


void readSensors() {
  const int samples = 100;
  long sum = 0;
  int maxRaw = 0;

  for (int i = 0; i < samples; i++) {
    int raw = analogRead(PH_PIN);
    sum += raw;

    if (raw > maxRaw) {
      maxRaw = raw;
    }

    delay(3);
  }

  float rawAvg = sum / (float)samples;
  phVoltage = rawAvg * (3.3 / 4095.0);


  estimatedPH = 7.0 - ((phVoltage - neutralVoltage) / slope);

  if (phVoltage > neutralVoltage + normalTolerance) {
    phStatus = "ACIDIC";
  }
  else if (phVoltage < neutralVoltage - normalTolerance) {
    phStatus = "BASIC";
  }
  else {
    phStatus = "NORMAL";
  }

  if (maxRaw >= 4090) {
    phStatus = "ADC HIGH";
  }


  sensors.requestTemperatures();
  tempC = sensors.getTempCByIndex(0);

  if (tempC == DEVICE_DISCONNECTED_C) {
    tempStatus = "ERROR";
  }
  else if (tempC < 20.0) {
    tempStatus = "COLD";
  }
  else if (tempC > 32.0) {
    tempStatus = "HOT";
  }
  else {
    tempStatus = "NORMAL";
  }
}


uint16_t getPHStatusColor() {
  if (phStatus == "ACIDIC") return ILI9341_RED;
  if (phStatus == "BASIC") return ILI9341_CYAN;
  if (phStatus == "NORMAL") return ILI9341_GREEN;
  if (phStatus == "ADC HIGH") return ILI9341_YELLOW;
  return ILI9341_WHITE;
}

uint16_t getTempStatusColor() {
  if (tempStatus == "HOT") return ILI9341_RED;
  if (tempStatus == "COLD") return ILI9341_CYAN;
  if (tempStatus == "NORMAL") return ILI9341_GREEN;
  if (tempStatus == "ERROR") return ILI9341_YELLOW;
  return ILI9341_WHITE;
}


