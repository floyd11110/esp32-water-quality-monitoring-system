  tft.print("For accurate pH, use buffer calibration.");


  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(1);
  tft.setCursor(10, 285);
  tft.print("Web: http://");
  tft.print(WiFi.localIP());
}


