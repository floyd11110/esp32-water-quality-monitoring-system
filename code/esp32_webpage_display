void handleRoot() {
  readSensors();
  server.send(200, "text/html", dashboardHTML());
}

void handleData() {
  readSensors();

  String json = "{";
  json += "\"temperature_c\":" + String(tempC, 2) + ",";
  json += "\"ph_voltage\":" + String(phVoltage, 3) + ",";
  json += "\"estimated_ph\":" + String(estimatedPH, 2) + ",";
  json += "\"ph_status\":\"" + phStatus + "\",";
  json += "\"temperature_status\":\"" + tempStatus + "\"";
  json += "}";

  server.send(200, "application/json", json);
}


void setup() {
  Serial.begin(115200);

  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);

  sensors.begin();


  tft.begin();
  tft.setRotation(3);
  tft.fillScreen(ILI9341_BLACK);

  tft.setTextColor(ILI9341_GREEN);
  tft.setTextSize(2);
  tft.setCursor(10, 20);
  tft.println("HYDRO DASHBOARD");

  tft.setTextColor(ILI9341_WHITE);
  tft.setCursor(10, 55);
  tft.println("Connecting WiFi...");


  WiFi.begin(ssid, password);

  Serial.print("Connecting to WiFi");

  int attempts = 0;

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
    attempts++;

    if (attempts > 40) {
      Serial.println();
      Serial.println("WiFi connection failed.");

      tft.fillScreen(ILI9341_BLACK);
      tft.setTextColor(ILI9341_RED);
      tft.setTextSize(2);
      tft.setCursor(10, 40);
      tft.println("WiFi Failed");
      tft.setCursor(10, 80);
      tft.println("Check SSID/PASS");

      delay(3000);
      ESP.restart();
    }
  }

  Serial.println();
  Serial.println("WiFi connected!");
  Serial.print("Open dashboard: http://");
  Serial.println(WiFi.localIP());

  tft.fillScreen(ILI9341_BLACK);
  tft.setTextColor(ILI9341_GREEN);
  tft.setTextSize(2);
  tft.setCursor(10, 20);
  tft.println("WiFi Connected");

  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(1);
  tft.setCursor(10, 60);
  tft.print("IP: ");
  tft.println(WiFi.localIP());

  delay(2000);


  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.begin();

  Serial.println("Web server started.");

  readSensors();
  drawTFTDashboard();
}


void loop() {
  server.handleClient();


  if (millis() - lastSensorRead >= 2000) {
    lastSensorRead = millis();
    readSensors();
  }


  if (millis() - lastTftUpdate >= 2000) {
    lastTftUpdate = millis();
    drawTFTDashboard();
  }
}
