#include <WiFi.h>
#include <WebServer.h>
#include <OneWire.h>
#include <DallasTemperature.h>


const char* ssid = "wifi name ";
const char* password = "password";


#define PH_PIN 34
#define ONE_WIRE_BUS 4


OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);


WebServer server(80);


float neutralVoltage = 2.40;  
float slope = 0.18;            
float normalTolerance = 0.10;  


float phVoltage = 0.0;
float estimatedPH = 7.0;
float tempC = 0.0;
String phStatus = "UNKNOWN";
String tempStatus = "UNKNOWN";


void readSensors() {

  const int samples = 100;
  long sum = 0;
  int maxRaw = 0;

  for (int i = 0; i < samples; i++) {
    int raw = analogRead(PH_PIN);
    sum += raw;

    if (raw > maxRaw) {
      maxRaw = raw;
    }

    delay(5);
  }

  float rawAvg = sum / (float)samples;
  phVoltage = rawAvg * (3.3 / 4095.0);

  
  estimatedPH = 7.0 - ((phVoltage - neutralVoltage) / slope);

  if (phVoltage > neutralVoltage + normalTolerance) {
    phStatus = "ACIDIC";
  }
  else if (phVoltage < neutralVoltage - normalTolerance) {
    phStatus = "BASIC / ALKALINE";
  }
  else {
    phStatus = "NORMAL / NEUTRAL";
  }

  if (maxRaw >= 4090) {
    phStatus += " - ADC HIGH";
  }


  sensors.requestTemperatures();
  tempC = sensors.getTempCByIndex(0);

  if (tempC == DEVICE_DISCONNECTED_C) {
    tempStatus = "SENSOR ERROR";
  }
  else if (tempC < 20.0) {
    tempStatus = "COLD";
  }
  else if (tempC > 32.0) {
    tempStatus = "HOT";
  }
  else {
    tempStatus = "NORMAL";
  }
}


